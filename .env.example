# Convex (Next.js client)
NEXT_PUBLIC_CONVEX_URL=

# Convex CLI / deployment name (from `npx convex dev`)
CONVEX_DEPLOYMENT=

# Secret for POST https://<deployment>.convex.site/api/issues (n8n "Save to Database" node)
# Set the same value in Convex Dashboard → Settings → Environment Variables
ISSUES_INGEST_SECRET=

# n8n — public submit URL (configure in frontend or server proxy; do not expose private keys)
# N8N_SUBMIT_ISSUE_URL=https://....n8n.cloud/webhook/city-reporter/submit-issue

# Optional: Clerk
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
